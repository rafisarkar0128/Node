{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES6",
    "resolveJsonModule": true,
    "paths": {
      "@root/*": ["./*"],
      "@src/*": ["./src/*"],
      "@db/*": ["./src/db/*"],
      "@utils/*": ["./src/utils/*"],
      "@structures/*": ["./src/structures/*"]
    }
  },
  "exclude": ["node_modules"]
}

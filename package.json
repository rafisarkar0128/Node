{
  "name": "node",
  "version": "4.1.2",
  "description": "A multipurpose discord bot.",
  "main": "src/index.js",
  "_moduleAliases": {
    "@root": ".",
    "@src": "src/",
    "@db": "src/db/",
    "@utils": "src/utils/",
    "@structures": "src/structures/"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "shard": "node src/shard.js",
    "devShard": "nodemon src/shard.js",
    "lint": "npx eslint --config eslint.config.js src",
    "format": "npx prettier --write .",
    "clearGlobal": "node scripts/clearGlobal.js",
    "clearGuild": "node scripts/clearGuild.js",
    "fetchEmojis": "node scripts/fetchEmojis.js"
  },
  "keywords": [
    "bot",
    "discord",
    "discord-bot",
    "javascript",
    "nodejs",
    "music-bot",
    "lavalink",
    "music"
  ],
  "author": "rafisarkar0128",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafisarkar0128/Node.git"
  },
  "bugs": {
    "url": "https://github.com/rafisarkar0128/Node/issues"
  },
  "homepage": "https://github.com/rafisarkar0128/Node#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "mongodb": "^7.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "undici": "^8.0.2"
  },
  "dependencies": {
    "chalk": "4.1.2",
    "discord-arts": "^0.7.1",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "figures": "^6.1.0",
    "genius-lyrics": "^4.4.7",
    "glob": "^13.0.6",
    "i18next": "^25.10.10",
    "i18next-fs-backend": "^2.6.3",
    "lavalink-client": "^2.10.0",
    "lru-cache": "^11.3.2",
    "luxon": "^3.7.2",
    "module-alias": "^2.3.4",
    "mongoose": "^9.4.1",
    "ms": "^2.1.3",
    "node-system-stats": "^2.0.5",
    "readline": "^1.3.0",
    "table": "^6.9.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6",
    "zlib-sync": "^0.1.10"
  },
  "pnpm": {
